# ─── MongoDB Atlas ───────────────────────────────
# 連線字串（含帳號密碼），喺 Atlas → Database → Connect 攞
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/revision?retryWrites=true&w=majority

# ─── OpenRouter AI ──────────────────────────────
# API Key：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Chat LLM（用嚟 RAG 對話、Quiz 出題、Summary 生成）
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# Embedding Model（用嚟文件索引同向量搜尋）
OPENROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
